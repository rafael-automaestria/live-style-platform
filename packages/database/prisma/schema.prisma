// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  PARTNER
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String?
  password      String?
  role          UserRole  @default(PARTNER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  enrollments      Enrollment[]
  posts            ForumPost[]
  comments         ForumComment[]
  responsibleLeads Lead[]         @relation("ResponsibleLeads")
}

// --- CRM Models (v2.0) ---

model Funnel {
  id        String   @id @default(uuid())
  name      String   // E-book, Indicação, Orgânico, etc.
  leads     Lead[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Stage {
  id        String   @id @default(uuid())
  name      String   // Compra Aprovada, Preencheu Formulário, etc.
  order     Int
  leads     Lead[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lead {
  id                String   @id @default(uuid())
  name              String
  email             String?  @unique
  whatsapp          String?
  status            String   @default("NEW")
  
  // Pipeline Relations
  funnelId          String
  funnel            Funnel   @relation(fields: [funnelId], references: [id])
  stageId           String
  stage             Stage    @relation(fields: [stageId], references: [id])
  
  // Assignment
  responsibleId     String?
  responsible       User?    @relation("ResponsibleLeads", fields: [responsibleId], references: [id])
  
  // Data (Notion/Typeform migration)
  properties        Json     @default("{}") // All qualitative and custom fields
  utms              Json?    // source, campaign, medium, etc.
  
  messages          Message[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Message {
  id         String   @id @default(uuid())
  leadId     String
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  channel    String   // "WHATSAPP", "INSTAGRAM", "TIKTOK", "EMAIL"
  direction  String   // "INBOUND", "OUTBOUND"
  content    String   @db.Text
  
  createdAt  DateTime @default(now())
}

// --- Partner Portal (Education) Models ---

model Course {
  id          String   @id @default(uuid())
  title       String
  description String?  @db.Text
  thumbnail   String?
  modules     Module[]
  enrollments Enrollment[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Module {
  id        String   @id @default(uuid())
  title     String
  order     Int
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons   Lesson[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lesson {
  id          String   @id @default(uuid())
  title       String
  videoUrl    String?
  content     String?  @db.Text
  order       Int
  moduleId    String
  module      Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Enrollment {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())

  @@unique([userId, courseId])
}

// --- Community Forum Models ---

model ForumPost {
  id          String   @id @default(uuid())
  title       String
  content     String   @db.Text
  authorId    String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  
  comments    ForumComment[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ForumComment {
  id          String   @id @default(uuid())
  content     String   @db.Text
  postId      String
  post        ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId    String
  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
